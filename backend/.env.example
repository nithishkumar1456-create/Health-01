# Database connection string (Supabase or PostgreSQL connection string)
# Leave blank or comment out to fall back to local SQLite database (db.sqlite3)
#
# Supabase connection string variants:
# - Session pooler (Port 6543): Use for serverless/short-lived hosting (e.g. Vercel functions, AWS Lambda)
#   Example: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# - Direct connection (Port 5432): Use for persistent server hosting (Render, Railway, VM, local runserver)
#   Example: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Django configuration
DJANGO_SECRET_KEY=django-insecure-your-secret-key-here-change-this-in-production
DJANGO_DEBUG=True

# CORS allowed origins (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OSM Overpass API — no key required, unlike the earlier Places plan

